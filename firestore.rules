rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Read-only for everyone, only server can write
    match /vote_tallies/{doc} {
      allow read: if true;
      allow write: if false; 
    }
    
    // Users can only create their own vote once
    match /mock_votes/{visitorId} {
      allow read: if true;
      allow create: if request.auth != null 
                    && !exists(/databases/$(database)/documents/mock_votes/$(visitorId));
      allow update, delete: if false;
    }
    
    // Only staff can write system alerts
    match /system_alerts/{alertId} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.auth.token.role == 'staff';
    }
    
    // Only staff can write timeline updates
    match /timeline_updates/{updateId} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.auth.token.role == 'staff';
    }
  }
}
